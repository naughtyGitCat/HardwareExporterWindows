<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  
  <Package Name="Hardware Exporter" 
           Language="1033" 
           Version="1.0.0.0" 
           Manufacturer="Hardware Exporter" 
           UpgradeCode="A1B2C3D4-E5F6-4A5B-8C9D-0E1F2A3B4C5D"
           InstallerVersion="200"
           Compressed="yes"
           Scope="perMachine">
    
    <SummaryInformation Description="Hardware Exporter Windows Service" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Hardware Exporter" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="SmartmontoolsComponents" />
    </Feature>

    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="HardwareExporter">
        <Directory Id="SmartctlDir" Name="smartctl" />
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable">
        <File Source="$(var.SourceDir)\HardwareExporterWindows.exe" />
      </Component>
      <Component Id="AppSettings">
        <File Source="$(var.SourceDir)\appsettings.json" />
      </Component>
      <Component Id="InstallScriptFile">
        <File Source="$(var.SourceDir)\install.ps1" />
      </Component>
    </ComponentGroup>

    <!--
      smartmontools (smartctl.exe + drivedb.h) is GPLv2+. It is bundled here as
      a separate, unmodified executable in its own subdirectory ("mere
      aggregation") and is invoked by HardwareExporter only as a child process.
      smartmontools' own LICENSE/AUTHORS travel with it in this subdirectory.

      Directory= is set on each Component explicitly because in WiX v4 the
      Directory attribute on ComponentGroup is not always honored when the
      Components contain unkeyed File elements; per-Component is the
      reliable way to land files in the smartctl\ subfolder.
    -->
    <ComponentGroup Id="SmartmontoolsComponents">
      <Component Id="SmartctlExe" Directory="SmartctlDir">
        <File Source="$(var.SourceDir)\smartctl\smartctl.exe" />
      </Component>
      <Component Id="SmartctlDriveDb" Directory="SmartctlDir">
        <File Source="$(var.SourceDir)\smartctl\drivedb.h" />
      </Component>
      <Component Id="SmartctlLicense" Directory="SmartctlDir">
        <File Source="$(var.SourceDir)\smartctl\COPYING.txt" />
      </Component>
      <Component Id="SmartctlAuthors" Directory="SmartctlDir">
        <File Source="$(var.SourceDir)\smartctl\AUTHORS.txt" />
      </Component>
      <Component Id="SmartctlReadme" Directory="SmartctlDir">
        <File Source="$(var.SourceDir)\smartctl\README.txt" />
      </Component>
    </ComponentGroup>

    <CustomAction Id="RunInstallScript"
                  Directory="INSTALLFOLDER"
                  ExeCommand="powershell.exe -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]install.ps1&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <InstallExecuteSequence>
      <Custom Action="RunInstallScript" After="InstallFiles" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <ui:WixUI Id="WixUI_Minimal" />

  </Package>
</Wix>
