{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "HardwareExporterWindows": "Information"
    }
  },
  "AllowedHosts": "*",
  "UseHttpsRedirection": false,
  "HardwareMonitor": {
    "EnableCpu": true,
    "EnableGpu": true,
    "EnableMemory": true,
    "EnableMotherboard": true,
    "EnableController": true,
    "EnableNetwork": true,
    "EnableStorage": true,
    "ScrapeIntervalSeconds": 15,
    "EmitLegacyMetricNames": true
  },
  "SmartMonitor": {
    "Enable": true,
    "SmartctlPath": "",
    "RefreshIntervalSeconds": 60,
    "InvocationTimeoutSeconds": 15,
    "DeviceExcludePatterns": []
  },
  "Urls": "http://0.0.0.0:9888"
}
